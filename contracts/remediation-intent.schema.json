{
  "$defs": {
    "ResourceSet": {
      "properties": {
        "cpu_request": {
          "title": "Cpu Request",
          "type": "string"
        },
        "memory_request": {
          "title": "Memory Request",
          "type": "string"
        }
      },
      "required": [
        "cpu_request",
        "memory_request"
      ],
      "title": "ResourceSet",
      "type": "object"
    }
  },
  "properties": {
    "cluster": {
      "title": "Cluster",
      "type": "string"
    },
    "namespace": {
      "title": "Namespace",
      "type": "string"
    },
    "workload": {
      "title": "Workload",
      "type": "string"
    },
    "workload_type": {
      "title": "Workload Type",
      "type": "string"
    },
    "container": {
      "title": "Container",
      "type": "string"
    },
    "current": {
      "$ref": "#/$defs/ResourceSet"
    },
    "recommended": {
      "$ref": "#/$defs/ResourceSet"
    },
    "recommendation_term": {
      "title": "Recommendation Term",
      "type": "string"
    },
    "last_reported": {
      "title": "Last Reported",
      "type": "string"
    },
    "stage": {
      "default": "proposed",
      "enum": [
        "proposed",
        "approved"
      ],
      "title": "Stage",
      "type": "string"
    },
    "monthly_saving_estimate": {
      "default": 0.0,
      "title": "Monthly Saving Estimate",
      "type": "number"
    },
    "decision": {
      "default": "block",
      "enum": [
        "approve",
        "block"
      ],
      "title": "Decision",
      "type": "string"
    },
    "reasons": {
      "items": {
        "type": "string"
      },
      "title": "Reasons",
      "type": "array"
    }
  },
  "required": [
    "cluster",
    "namespace",
    "workload",
    "workload_type",
    "container",
    "current",
    "recommended",
    "recommendation_term",
    "last_reported"
  ],
  "title": "Intent",
  "type": "object"
}
